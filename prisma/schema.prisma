generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "mysql"
}

model Usuario {
  id             Int            @id @default(autoincrement())
  nome           String         @db.VarChar(100)
  email          String         @unique(map: "email") @db.VarChar(150)
  senha_hash     String         @db.VarChar(255)
  fk_foto_perfil Int            @default(1)
  status         UsuarioStatus? @default(ativo)
  criado_em      DateTime?      @default(now()) @db.DateTime(0)
  atualizado_em  DateTime?      @updatedAt
  encerrado_em   DateTime?      @db.DateTime(0)

  foto_perfil FotoPerfil @relation(fields: [fk_foto_perfil], references: [id])

  tokens pwd_reset_token[]

  plantas Planta[]
}

enum UsuarioStatus {
  ativo
  inativo
}

model FotoPerfil {
  id       Int    @id @default(autoincrement())
  path_url String @db.VarChar(255)

  usuarios Usuario[]
}

model pwd_reset_token {
  id            Int       @id @default(autoincrement())
  fk_usuario_id Int
  token_hash    String    @db.VarChar(255)
  expira_em     DateTime
  encerrado_em  DateTime?
  criado_em     DateTime? @default(now())

  usuario Usuario @relation(fields: [fk_usuario_id], references: [id])
}

model Planta {
  id              Int       @id @default(autoincrement())
  fk_usuario_id   Int
  fk_local_id     Int?
  nome_popular    String    @db.VarChar(100)
  nome_cientifico String?   @db.VarChar(100)
  apelido         String?   @db.VarChar(100)
  foto_url        String?   @db.VarChar(255)
  data_aquisicao  DateTime? @db.Date
  observacao      String?   @db.VarChar(255)
  criado_em       DateTime  @default(now()) @db.DateTime(0)
  atualizado_em   DateTime  @updatedAt

  local Local? @relation(fields: [fk_local_id], references: [id])

  usuario Usuario @relation(fields: [fk_usuario_id], references: [id])

  cuidados Cuidado[]
}

model Local {
  id     Int      @id @default(autoincrement())
  nome   String   @db.VarChar(100)
  planta Planta[]
}

// O Domínio (Rega, Poda, Adubação)
model CuidadoTipo {
  id        String  @id @default(uuid())
  nome      String
  descricao String?

  cuidados Cuidado[]
}

// O Planejamento (O que e quando fazer)
model Cuidado {
  id                   String   @id @default(uuid())
  frequencia_dias      Int
  proxima_data         DateTime
  quantidade_instrucao String?  @db.VarChar(80)
  horario_preferencial String?
  ativo                Boolean  @default(true)
  criado_em            DateTime @default(now())
  atualizado_em        DateTime @updatedAt

  planta_id Int
  planta    Planta @relation(fields: [planta_id], references: [id])

  tipo_id String
  tipo    CuidadoTipo @relation(fields: [tipo_id], references: [id])

  historicos HistoricoCuidado[]
}

// Definindo as opções possíveis
enum StatusCuidado {
  CONCLUIDO
  PULADO
  ATRASADO
  CANCELADO
}

model HistoricoCuidado {
  id              String        @id @default(uuid())
  data_realizacao DateTime      @default(now())
  observacoes     String?
  status          StatusCuidado
  criado_em       DateTime      @default(now())
  atualizado_em   DateTime      @updatedAt

  cuidado_id String
  cuidado    Cuidado @relation(fields: [cuidado_id], references: [id])
}
